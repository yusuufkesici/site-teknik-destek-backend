meta {
  name: 09 START eventi (IN_PROGRESS)
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/assignments/{{assignmentId}}/status
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{techToken}}
}

body:json {
  {
    "event": "START"
  }
}

assert {
  res.status: eq 201
  res.body.assignmentStatus: eq ACTIVE
  res.body.startedAt: isDefined
}
