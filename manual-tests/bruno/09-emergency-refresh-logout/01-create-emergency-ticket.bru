meta {
  name: 01 Emergency ticket olusturma (RESIDENT)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/tickets
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{residentToken}}
}

body:json {
  {
    "facilityId": "{{panoramaUnitA1Id}}",
    "title": "Elektrik panosundan yanik kokusu",
    "description": "Daire panosundan yanik kokusu geliyor ve sigorta surekli atiyor, acil mudahale gerekiyor.",
    "category": "ELECTRICAL",
    "urgency": "EMERGENCY"
  }
}

assert {
  res.status: eq 201
  res.body.status: eq OPEN
  res.body.urgency: eq EMERGENCY
  res.body.slaTargetAt: isDefined
}

script:post-response {
  bru.setVar("emergencyTicketId", res.body.id);
}

docs {
  Seed Panorama sozlesmesi emergencyCoverage=true oldugu icin SLA hedefi
  EMERGENCY_SLA_HOURS uzerinden hesaplanir. Bu ticket ayrica negatif
  attachment MIME senaryosunda hedef olarak kullanilir (OPEN durumda
  kalir).
}
