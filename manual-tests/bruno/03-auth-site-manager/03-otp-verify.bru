meta {
  name: 03 SITE_MANAGER OTP verify
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/otp/verify
  body: json
  auth: none
}

body:json {
  {
    "phoneNumber": "{{managerPhone}}",
    "code": "{{managerOtp}}"
  }
}

assert {
  res.status: eq 200
  res.body.accessToken: isDefined
  res.body.user.role: eq SITE_MANAGER
}

script:post-response {
  bru.setVar("managerToken", res.body.accessToken);
}
