meta {
  name: 01 Yanlis OTP - once gecerli istek (MARINA RESIDENT)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/otp/request
  body: json
  auth: none
}

body:json {
  {
    "phoneNumber": "{{marinaResidentPhone}}"
  }
}

assert {
  res.status: eq 200
}

docs {
  Yanlis OTP senaryosu icin taze bir challenge uretilir. Marina sakini
  pozitif zincirde kullanilmadigi icin diger adimlari etkilemez. Yanlis
  deneme sayaci artar (OTP_MAX_ATTEMPTS=5); senaryo tek deneme yapar.
}
