meta {
  name: 13 Inaktif kullanici OTP istegi - generic 200
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/auth/otp/request
  body: json
  auth: none
}

body:json {
  {
    "phoneNumber": "{{disposablePhone}}"
  }
}

assert {
  res.status: eq 200
  res.body.message: isDefined
}

docs {
  Enumeration korumasi: inaktif kullanici icin de ayni generic 200 doner
  ama OTP uretilmez ve SMS gonderilmez. Kanit bir sonraki adimda: dev
  inbox bu numara icin 404 dondurur.
}
