NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://app:app@localhost:5432/site_support?schema=public

# Auth
# JWT_ACCESS_SECRET rotasyon destekler: virgulle ayrilmis birden fazla deger
# olabilir (imzalama ilk degeri kullanir, dogrulama tumunu dener). Her
# segment en az 32 karakter olmalidir.
JWT_ACCESS_SECRET=change-me-32-bytes-minimum-secret
JWT_ACCESS_EXPIRES_IN=900
REFRESH_TOKEN_PEPPER=change-me-32-bytes-minimum-secret
REFRESH_TOKEN_EXPIRES_IN=2592000

# OTP
OTP_HMAC_SECRET=change-me-32-bytes-minimum-secret
OTP_EXPIRES_IN_SECONDS=180
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# SMS
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./var/uploads
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false

CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=debug
