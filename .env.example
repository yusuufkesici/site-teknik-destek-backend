NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://app:app@localhost:5432/site_support?schema=public

# Auth
# JWT_ACCESS_SECRET rotasyon destekler: virgulle ayrilmis birden fazla deger
# olabilir (imzalama ilk degeri kullanir, dogrulama tumunu dener). Her
# segment en az 32 karakter olmalidir.
JWT_ACCESS_SECRET=change-me-32-bytes-minimum-secret
JWT_ACCESS_EXPIRES_IN=900
REFRESH_TOKEN_PEPPER=change-me-32-bytes-minimum-secret
REFRESH_TOKEN_EXPIRES_IN=2592000

# OTP
OTP_HMAC_SECRET=change-me-32-bytes-minimum-secret
OTP_EXPIRES_IN_SECONDS=180
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# SMS
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./var/uploads
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false

CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=debug

# Tickets
EMERGENCY_SLA_HOURS=2

# Outbox relay / notification delivery (Faz 8 Dilim 1)
# OutboxRelay ve NotificationDeliveryRelay ayni dort sayisal degeri
# paylasir. OUTBOX_RELAY_ENABLED production'da ZORUNLUDUR (varsayilani
# yoktur) - ilk deploy'da once "false" ile baslayip backlog-temizleme
# migration'inin uygulandigi dogrulandiktan sonra "true"ya cevrilmesi
# onerilir (docs/phase-8-plan.md Bolum 9.1). development/test icin
# bos birakilabilir (development varsayilani true, test her zaman kapali).
OUTBOX_RELAY_ENABLED=true
OUTBOX_RELAY_POLL_INTERVAL_MS=5000
OUTBOX_RELAY_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_CLAIM_LEASE_MS=60000

# Scheduled jobs: ContractExpiringScanJob / InvoiceOverdueScanJob (Faz 8)
# BACKGROUND_JOBS_ENABLED de OUTBOX_RELAY_ENABLED ile ayni kuralla
# production'da ZORUNLUDUR (varsayilani yoktur). development/test icin
# bos birakilabilir (development varsayilani true, test her zaman kapali).
CONTRACT_EXPIRY_LEAD_DAYS=30
BACKGROUND_JOBS_ENABLED=true

# Dev-only SMS inbox (Faz 9 karar #2)
# Manuel kabul testinde mock OTP'nin guvenli elde edilmesi icin
# GET /api/v1/dev/sms/:phone/last-otp endpoint'ini acar. YALNIZ
# NODE_ENV=development VE DEV_SMS_INBOX_ENABLED=true iken etkindir;
# production/test ortaminda 'true' verilse bile route mount edilmez.
# Varsayilan false'tur. OTP yalniz process belleginde kisa TTL ile
# tutulur; loglanmaz, veritabanina veya dosyaya yazilmaz.
DEV_SMS_INBOX_ENABLED=false
